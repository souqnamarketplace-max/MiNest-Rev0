# ================================================================
# MiNest Environment Variables — SECURITY GUIDE
# ================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git (it's in .gitignore)
#
# VITE_ prefix = EXPOSED TO CLIENT BROWSER (public values only!)
# No prefix = SERVER ONLY (never exposed to browser)
# ================================================================

# ✅ SAFE: Supabase public URL (not a secret)
VITE_SUPABASE_URL=https://your-project.supabase.co

# ✅ SAFE: Supabase anon key (public, protected by RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ✅ SAFE: Stripe publishable key (public by design)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# ============================================================
# 🔐 SERVER-SIDE ONLY — NEVER add VITE_ prefix to these!
# ============================================================

# 🔒 Supabase service role (bypasses RLS — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 🔒 Stripe secret key (server only — never expose to browser)
STRIPE_SECRET_KEY=sk_live_your-secret-key

# 🔒 Stripe webhook secret (server only)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# 🔒 Anthropic API key (server only — NEVER use VITE_ prefix!)
# ❌ WRONG: VITE_ANTHROPIC_API_KEY (exposes key to all users!)
# ✅ CORRECT: ANTHROPIC_API_KEY (server proxy only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 🔒 Resend email API key (server only)
RESEND_API_KEY=re_your-key-here

# 🔒 Cron job secret (server only)
CRON_SECRET=your-random-secret-here
